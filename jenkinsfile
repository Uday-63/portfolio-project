pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main',
                url: 'https://github.com/your-username/portfolio-project.git'
            }
        }

        stage('Verify Photo Exists') {
            steps {
                sh '''
                echo "Checking image folder..."
                ls -l images
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t portfolio-image .'
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker rm -f portfolio-container || true
                docker run -d -p 4000:80 --name portfolio-container portfolio-image
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Website deployed with updated photo"
        }
        failure {
            echo "❌ Pipeline failed"
        }
    }
}

